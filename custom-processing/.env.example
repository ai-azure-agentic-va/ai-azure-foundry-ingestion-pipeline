# =============================================================================
# Custom Processing — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the actual values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets.
# =============================================================================


# =============================================================================
# DEPLOYMENT CONFIGURATION (deploy.sh / deploy.ps1 only — NOT pushed as app settings)
# =============================================================================
DEPLOY_SUBSCRIPTION_ID=<your-azure-subscription-id>
DEPLOY_LOCATION=eastus
DEPLOY_RG_NAME=<your-resource-group>

DEPLOY_FUNC_APP_NAME=<your-custom-func-app-name>
DEPLOY_FUNC_STORAGE_ACCOUNT=<your-func-storage-account>

# Application Insights — optional. Uncomment and set to enable monitoring.
# If omitted, the Function App is created without App Insights.
# DEPLOY_APP_INSIGHTS=<your-app-insights-name>

DEPLOY_IS_ACTIVE=true

DEPLOY_SEARCH_SERVICE=<your-search-service-name>
DEPLOY_SEARCH_RG=<your-search-resource-group>

DEPLOY_FOUNDRY_ACCOUNT=<your-foundry-resource-name>
DEPLOY_FOUNDRY_RG=<your-foundry-resource-group>


# =============================================================================
# APP SETTINGS (pushed to Azure Function App)
# =============================================================================

# Processing Path
DOC_PROCESSING=CUSTOM_LIBRARIES

# Trigger mode — defaults to BLOB if not set (simplest, no Event Grid/Queue needed)
# Options: BLOB, EVENTGRID_QUEUE, EVENTGRID_DIRECT
TRIGGER_MODE=BLOB

QUEUE_NAME=doc-processing-queue

# ADLS Gen2
ADLS_ACCOUNT_NAME=<your-storage-account>
ADLS_CONTAINER_RAW=raw-documents
ADLS_CONTAINER_FAILED=raw-documents-failed
ADLS_CONTAINER_STATE=processing-state
ADLS_QUEUE_CONNECTION__queueServiceUri=https://<your-storage-account>.queue.core.windows.net
ADLS_BLOB_CONNECTION__blobServiceUri=https://<your-storage-account>.blob.core.windows.net
ADLS_BLOB_CONNECTION__queueServiceUri=https://<your-storage-account>.queue.core.windows.net

# Azure AI Foundry (Embeddings only)
FOUNDRY_ENDPOINT=https://<your-foundry-resource>.cognitiveservices.azure.com
FOUNDRY_API_VERSION=2024-06-01
FOUNDRY_EMBEDDING_DEPLOYMENT=text-embedding-3-small
FOUNDRY_EMBEDDING_DIMENSIONS=1536
# FOUNDRY_API_KEY=                          # Optional: for local dev only

# Azure AI Search (auth via Managed Identity — assign "Search Index Data Contributor" + "Search Service Contributor" roles)
SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
SEARCH_INDEX_NAME=nfcu-rag-index

# Chunking
CHUNK_SIZE_TOKENS=1024
CHUNK_OVERLAP_TOKENS=200

# PII (Presidio + spaCy, runs locally)
PII_ENABLED=true
PII_CONFIDENCE_THRESHOLD=0.8

# Indexing
BATCH_SIZE=100

# Azure Functions Runtime
AzureWebJobsFeatureFlags=EnableWorkerIndexing

# Trigger enable/disable — deploy.sh auto-configures, no need to change manually
AzureWebJobs.process_new_document.Disabled=true
AzureWebJobs.process_queue_document.Disabled=true
AzureWebJobs.process_blob_document.Disabled=false

# Logging
LOG_LEVEL=INFO
