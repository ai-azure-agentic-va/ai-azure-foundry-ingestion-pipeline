# =============================================================================
# AI Foundry Processing — Single Source of Truth
# =============================================================================
# Function App: ai-foundry-processing-dev
# Processing Path: AI_FOUNDRY_SERVICES
#
# This file contains ALL configuration for the AI Foundry Function App.
# Two sections:
#   1. DEPLOY_* — Deployment variables (used by deploy.sh only, NOT pushed as app settings)
#   2. App Settings — Pushed to Azure Function App by deploy.sh
#
# deploy.sh reads this file for both infrastructure values and app settings.
# Values here can be overridden at runtime:  TRIGGER_MODE=EVENTGRID_DIRECT ./deploy.sh
# Parent orchestrator (../deploy.sh) exports override this file via env inheritance.
#
# IMPORTANT: This file contains secrets (SEARCH_ADMIN_KEY). Do NOT commit to git.
# =============================================================================


# =============================================================================
# DEPLOYMENT CONFIGURATION (deploy.sh only — NOT pushed as app settings)
# =============================================================================
# Prefix: DEPLOY_ — filtered out when pushing app settings to Azure.
# These control Azure resource creation, RBAC, and Function App provisioning.
# =============================================================================

# Azure subscription and region
DEPLOY_SUBSCRIPTION_ID=aa4635d7-32d0-4ba8-ac90-3cc60e9b18a9
DEPLOY_LOCATION=eastus
DEPLOY_RG_NAME=rg-nfcu-ingestion-dev

# Function App name and its dedicated storage account
DEPLOY_FUNC_APP_NAME=ai-foundry-processing-dev
DEPLOY_FUNC_STORAGE_ACCOUNT=stfuncfndryprocdev

# Application Insights — optional. Remove or leave empty to skip.
# If not set, deploy creates the Function App without App Insights.
# DEPLOY_APP_INSIGHTS=appi-doc-processing-dev

# Whether this app is the ACTIVE processing path (controls trigger enable/disable)
DEPLOY_IS_ACTIVE=true

# AI Search service name (for RBAC and index creation; app uses SEARCH_ENDPOINT below)
DEPLOY_SEARCH_SERVICE=aisearchnfcu
DEPLOY_SEARCH_RG=MDSPRUSE2LSEGRG

# AI Foundry Cognitive Services account (for RBAC; app uses FOUNDRY_ENDPOINT below)
DEPLOY_FOUNDRY_ACCOUNT=adf-agent-prj-resource
DEPLOY_FOUNDRY_RG=MDSPRUSE2LSEGRG



# =============================================================================
# APP SETTINGS (pushed to Azure Function App by deploy.sh)
# =============================================================================


# -----------------------------------------------------------------------------
# Processing Path
# -----------------------------------------------------------------------------
DOC_PROCESSING=AI_FOUNDRY_SERVICES

# TRIGGER_MODE controls how new documents are detected and processed.
# Options:
#   EVENTGRID_QUEUE  — Event Grid routes BlobCreated events to a Queue, Function reads from Queue (best retry semantics, production default)
#   EVENTGRID_DIRECT — Event Grid fires directly to the Function (lowest latency, no queue buffer)
#   BLOB             — Blob trigger polls ADLS directly for new files (simplest setup, no Event Grid or Queue needed)
# To switch: change TRIGGER_MODE and re-run deploy.sh — deploy.sh auto-enables/disables the correct triggers.
TRIGGER_MODE=BLOB

# -----------------------------------------------------------------------------
# Trigger Configuration — Queue
# -----------------------------------------------------------------------------
# Queue name used when TRIGGER_MODE=EVENTGRID_QUEUE. Ignored in other modes.
QUEUE_NAME=doc-processing-queue

# -----------------------------------------------------------------------------
# ADLS Gen2 — Document Landing Zone
# -----------------------------------------------------------------------------
ADLS_ACCOUNT_NAME=stnfcuingestdev
ADLS_CONTAINER_RAW=raw-documents
ADLS_CONTAINER_FAILED=raw-documents-failed
ADLS_CONTAINER_STATE=processing-state

# Identity-based connections (Managed Identity — no storage account keys)
ADLS_QUEUE_CONNECTION__queueServiceUri=https://stnfcuingestdev.queue.core.windows.net
ADLS_BLOB_CONNECTION__blobServiceUri=https://stnfcuingestdev.blob.core.windows.net
ADLS_BLOB_CONNECTION__queueServiceUri=https://stnfcuingestdev.queue.core.windows.net

# -----------------------------------------------------------------------------
# Azure AI Foundry — Multi-Service Endpoint
# -----------------------------------------------------------------------------
# Single Foundry resource providing: Content Understanding, Language PII, Embeddings
FOUNDRY_ENDPOINT=https://adf-agent-prj-resource.cognitiveservices.azure.com

# Optional: API key for local development (production uses Managed Identity)
# FOUNDRY_API_KEY=

# -----------------------------------------------------------------------------
# AI Foundry — Content Understanding (Stage 2: Parsing + Image Verbalization)
# -----------------------------------------------------------------------------
# Requires gpt-4.1-mini + text-embedding-3-large deployed in Foundry.
# Run sample_update_defaults.py one-time to configure model mappings.
FOUNDRY_ANALYZER_ID=prebuilt-documentSearch

# -----------------------------------------------------------------------------
# AI Foundry — Language PII (Stage 4: PII Detection & Redaction)
# -----------------------------------------------------------------------------
# Optional: Override PII endpoint/key if different from main Foundry endpoint
# FOUNDRY_PII_ENDPOINT=
# FOUNDRY_PII_KEY=

# -----------------------------------------------------------------------------
# AI Foundry — Embeddings (Stage 5)
# -----------------------------------------------------------------------------
FOUNDRY_EMBEDDING_DEPLOYMENT=text-embedding-3-large
FOUNDRY_EMBEDDING_DIMENSIONS=3072
FOUNDRY_EMBEDDING_MODEL=text-embedding-3-large

# -----------------------------------------------------------------------------
# Azure AI Search — Vector + Keyword + Semantic Search Index
# -----------------------------------------------------------------------------
SEARCH_ENDPOINT=https://aisearchnfcu.search.windows.net
SEARCH_INDEX_NAME=custom-kb-index
SEARCH_ADMIN_KEY=<replace-with-actual-key>

# -----------------------------------------------------------------------------
# Chunking Configuration (Stage 3)
# -----------------------------------------------------------------------------
CHUNK_SIZE_TOKENS=1024
CHUNK_OVERLAP_TOKENS=200

# -----------------------------------------------------------------------------
# PII Configuration (Stage 4)
# -----------------------------------------------------------------------------
PII_ENABLED=true
PII_CONFIDENCE_THRESHOLD=0.5

# -----------------------------------------------------------------------------
# Indexing Configuration (Stage 6)
# -----------------------------------------------------------------------------
BATCH_SIZE=100

# -----------------------------------------------------------------------------
# Azure Functions Runtime
# -----------------------------------------------------------------------------
AzureWebJobsFeatureFlags=EnableWorkerIndexing

# Trigger enable/disable — deploy.sh auto-configures these based on TRIGGER_MODE.
# You can also set them manually here. Only ONE document trigger should be enabled at a time.
#
# EVENTGRID_QUEUE mode:  process_queue_document=false, others=true
# EVENTGRID_DIRECT mode: process_new_document=false, others=true
# BLOB mode:             process_blob_document=false, others=true
# To disable ALL triggers (inactive app): set all to true
AzureWebJobs.process_new_document.Disabled=true
AzureWebJobs.process_queue_document.Disabled=true
AzureWebJobs.process_blob_document.Disabled=false

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
